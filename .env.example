# SentinelAI (vigilex) -- Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=vigilex
POSTGRES_USER=vigilex
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Read-only Grafana datasource user (vigilex_readonly role in PostgreSQL)
GRAFANA_READONLY_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API Keys ──────────────────────────────────────────────────
# SentinelAI REST API key -- required for all /coding-results endpoints
# Generate a strong random value, e.g.: openssl rand -hex 32
API_KEY=CHANGE_ME_STRONG_API_KEY

# openFDA: free key at https://open.fda.gov/apis/authentication/
# Raises rate limit from 1k to 120k requests/day
OPENFDA_API_KEY=

# Groq: optional, for dev/testing only (NOT for production -- use Ollama)
GROQ_API_KEY=

# ── MLflow ────────────────────────────────────────────────────
# No separate key needed -- uses POSTGRES_* above

# ── Notes ─────────────────────────────────────────────────────
# Ollama runs locally on the server (no API key needed)
# PostgreSQL port 5432 is bound to 127.0.0.1 only (not public)
# Grafana port 3000 is public -- protect with Hetzner firewall
